# EDINET API v2 Subscription Key
# 取得先: https://disclosure2dl.edinet-fsa.go.jp/guide/static/disclosure/WZEK0110.html
EDINET_API_KEY=your_subscription_key_here

# --- EDGAR (SEC) MCP server: `edgar-mcp` (requires `edinet-mcp[edgar]`) ---
# SEC requires every request to declare an identity ("Name <email>").
# The edgar-mcp server fails fast at startup if this is unset.
EDGAR_IDENTITY=Your Name <you@example.com>
# Optional: edgartools local cache dir (default ~/.edgar)
# EDGAR_CACHE_DIR=~/.edgar
# Optional: default cap on returned filing text (default 20000)
# EDGAR_MAX_TEXT_CHARS=20000
